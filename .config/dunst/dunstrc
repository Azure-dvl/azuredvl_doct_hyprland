[global]
    monitor = 1
    follow=none
    font = 3270 Nerd Font Mono 13
    width = 250
    height = 150
    origin = top-right
    icon_theme = breeze-dark
    enable_recursive_icon_lookup = true
    offset = 20x20
    frame_width = 2
    frame_color = "#1e66f5"
    separator_color = frame
    padding = 5
    horizontal_padding = 5
    line_height = 0
    idle_threshold = 120
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = center
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    sticky_history = yes
    history_length = 20
    browser = xdg-open
    always_run_script = true

[urgency_low]
    background = "#eff1f5"
    foreground = "#4c4f69"
    timeout = 5

[urgency_normal]
    background = "#eff1f5"
    foreground = "#4c4f69"
    timeout = 10

[urgency_critical]
    background = "#eff1f5"
    foreground = "#4c4f69"
    frame_color = "#fe640b"
    timeout = 0
